{
  "name": "offdex",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "dev:bridge": "turbo dev --filter=@offdex/bridge",
    "dev:control-plane": "turbo dev --filter=@offdex/control-plane",
    "dev:mobile": "turbo dev --filter=@offdex/mobile",
    "dev:relay": "turbo dev --filter=@offdex/relay",
    "dev:web": "turbo dev --filter=@offdex/web",
    "lint": "turbo lint",
    "pack:npm": "npm pack ./packages/npm",
    "postinstall": "node scripts/patch-react-native-gradle-plugin.mjs",
    "release:tag": "node scripts/release-tag.mjs",
    "test": "turbo test",
    "test:install-smoke": "node scripts/smoke-install.mjs",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
