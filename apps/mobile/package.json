{
  "name": "@offdex/mobile",
  "version": "0.0.2",
  "main": "index.ts",
  "scripts": {
    "build": "mkdir -p dist && echo mobile > dist/.keep && tsc --noEmit",
    "dev": "expo start",
    "lint": "tsc --noEmit",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "bun test --pass-with-no-tests",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@offdex/protocol": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "expo": "^55.0.0",
    "expo-blur": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-camera": "~55.0.11",
    "expo-clipboard": "~55.0.9",
    "expo-haptics": "~55.0.9",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.11",
    "expo-navigation-bar": "~55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.11",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
